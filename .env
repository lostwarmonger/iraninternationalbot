# توکن ربات تلگرام (از @BotFather دریافت کنید)
BOT_TOKEN=

# آیدی چت تلگرام که اسکرین شات توسط بات آنجا ارسال می‌شود. توجه داشته باشید که برای کانال یا گروه، لازم است بات ادمین باشد و دسترسی های لازم را داشته باشد (مثلاً @username یا عدد چت خصوصی/گروه)
CHAT_ID=

# لینک یوتیوب لایو مورد نظر
YOUTUBE_URL=https://www.youtube.com/watch?v=5JDxjsAVaGk

# کوکی‌های یوتیوب (اختیاری - برای دسترسی به محتوای محدود)
# فرمت: "نام1=مقدار1; نام2=مقدار2"
YOUTUBE_COOKIES=

# مسیر ذخیره اسکرین‌شات (اختیاری - پیش‌فرض: snapshot.jpg)
OUTPUT_PATH=snapshot.jpg

# زمان‌بندی اجرا به دقیقه (برای cron) - پیش‌فرض: هر ۳ دقیقه
INTERVAL_SECONDS=120

USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36


# فعال/غیرفعال کردن برش
CROP_ENABLED=true

#  مختصات و ابعاد ناحیه ویدیو + کامنت‌ها
# (شروع از چپ، شروع از بالا، عرض، ارتفاع)
CROP_X=0
CROP_Y=55
CROP_WIDTH=1360
CROP_HEIGHT=555
